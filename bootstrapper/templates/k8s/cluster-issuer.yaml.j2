apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ issuer_name }}
spec:
  acme:
    email: {{ email }}
    server: https://acme-v02.api.letsencrypt.org/directory
    privateKeySecretRef:
      name: {{ issuer_name }}-key
    solvers:
      - http01:
          ingress:
            ingressClassName: traefik
