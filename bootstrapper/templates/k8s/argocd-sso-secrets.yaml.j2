apiVersion: v1
kind: Secret
metadata:
  name: argocd-secret
  namespace: argocd
stringData:
  # The $oidc.authentik.clientSecret reference in argocd-cm resolves from this secret.
  oidc.authentik.clientSecret: {{ oidc_client_secret }}
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-forgejo-token
  namespace: argocd
stringData:
  token: {{ forgejo_api_token }}
---
apiVersion: v1
kind: Secret
metadata:
  name: forgejo-repo-creds
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repo-creds
stringData:
  type: git
  url: https://{{ forgejo_domain }}/
  username: {{ forgejo_admin_username }}
  password: {{ forgejo_api_token }}
